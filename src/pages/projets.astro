---
import Contact from '@/components/Contact.astro';
import Navbar from '@/components/Navbar.astro';
import Project from '@/components/Project.astro';
import { Badge } from '@/components/ui/badge';
import Layout from '@/layouts/Layout.astro';
import { projects } from '@/lib/projects';
import "@/styles/global.css";
---

<Layout>
  <Navbar />
  <section class="bg-neutral-950 pt-24 pb-16 md:pt-40 md:pb-32 px-4 md:px-16 flex flex-col justify-center items-center gap-10 md:gap-20">
    <div class="flex flex-col gap-4 justify-center items-center max-w-3xl">
      <Badge>Nos réalisations</Badge>
      <h1 class="text-center font-display text-3xl md:text-5xl font-medium bg-gradient-to-r text-transparent from-[#BDB0F0] via-white to-[#AE5DC7] bg-clip-text">
        L'ensemble des projets que nous avons réalisés
      </h1>
      <p class="text-base md:text-lg text-white/70 font-normal text-center px-4">
        Une sélection complète de nos collaborations, du MVP à la plateforme en production.
      </p>
    </div>
    <div class="pb-4 w-full md:w-auto">
      {projects.map((project) => (
        <Project
          title={project.title}
          description={project.description}
          stack={project.stack}
          image={project.image}
          link={project.link}
          variant={project.variant}
        />
      ))}
    </div>
  </section>
  <Contact />
</Layout>
