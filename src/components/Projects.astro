---
import Project from "./Project.astro";
import { featuredProjects } from "../lib/projects";
import { Badge } from "./ui/badge";
import { Button } from "./ui/button";
---

<div id="projects" class="bg-neutral-950 py-16 md:py-32 px-4 md:px-16 flex flex-col justify-center items-center gap-10 md:gap-20">
  <div class="flex flex-col gap-4 justify-center items-center max-w-3xl">
    <Badge>Projets réalisés</Badge>
    <h2 class="text-center font-display text-3xl md:text-5xl font-medium bg-gradient-to-r text-transparent from-[#BDB0F0] via-white to-[#AE5DC7] bg-clip-text">Ce que nous avons déjà accompli pour nos clients</h2>
    <p class="text-base md:text-lg text-white/70 font-normal text-center px-4">Des projets concrets, sur mesure, avec des résultats à la clé :</p>
  </div>
  <div class="pb-4 w-full md:w-auto">
    {featuredProjects.map((project) => (
      <Project
        title={project.title}
        description={project.description}
        stack={project.stack}
        image={project.image}
        link={project.link}
        variant={project.variant}
      />
    ))}
  </div>
  <a href="/projets" class="w-full md:w-auto">
    <Button variant="secondary" className="w-full md:w-auto">Découvrir tous les projets</Button>
  </a>
</div>
